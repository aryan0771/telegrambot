# Telegram API Credentials (get from my.telegram.org)
API_ID=
API_HASH=

# Telethon Session String (leave empty for first login, then save the output here if using environment vars instead of db)
# Alternatively, you can just rely on the session database.
SESSION=

# The source and destination channels (can be ID like -100xxx, or username)
# If using IDs, make sure they are integers or start with -100
SOURCE_CHANNEL=
DESTINATION_CHANNEL=

# Logging level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
